# Copy this file to .env and fill in real values. .env is gitignored.
# All values are optional: without them the app runs in offline mode
# (template-based recommendations, Slack alerts logged instead of sent).

# Anthropic API key. Enables LLM-written recommendations.
ANTHROPIC_API_KEY=

# Model used by the narrator.
REVOPS_MODEL=claude-opus-4-8

# Slack incoming webhook. Enables real severity-3 alerts.
SLACK_WEBHOOK_URL=

# Link used in the Slack alert button.
REVOPS_DASHBOARD_URL=http://localhost:8000
